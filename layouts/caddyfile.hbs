# ─────────────────────────────────────────────────────────────────────
# Caddy facade — GENERATED by mikser. DO NOT EDIT THIS FILE.
# Source of truth: runtime.routes (the route registry) + caddyfile.hbs.
# To change the output: edit layouts/caddyfile.hbs and rebuild.
# To regenerate: rebuild mikser (mikser --server).
#
# TRUST PROXY: mikser's loopback-only enforcement (mcp / decap backend /
# loopback api endpoints) depends on `trust proxy`. It defaults to
# 'loopback', which is correct when Caddy runs on the SAME HOST as this
# mikser instance — the topology this file assumes. If you move Caddy to
# another host or container, set config.server.trustProxy to that hop
# (e.g. 'uniquelocal' or the subnet) or those endpoints will 403 every
# request. Don't expose mikser's listener port directly — Caddy is the
# only intended way in.
# ─────────────────────────────────────────────────────────────────────

{{data.origin}} {
	# Static output served straight from disk — survives a mikser
	# restart; only the dynamic routes below need mikser alive.
	root * {{data.outputFolder}}

{{#each data.proxied}}
	@{{plugin}}{{@index}} path {{path}} {{path}}/*
	handle @{{plugin}}{{@index}} {
{{#if streaming}}
		reverse_proxy {{../data.upstream}} {
			flush_interval -1   # {{plugin}} streams (SSE/WS) — never buffer
		}
{{else}}
		reverse_proxy {{../data.upstream}}
{{/if}}
	}

{{/each}}
	# Files first, mikser never sees a request it doesn't need to.
	handle {
		try_files {path} {path}/index.html
		file_server
	}
}

{{#if data.loopback.length}}
# Not proxied — loopback-only, reachable on the mikser host only:
{{#each data.loopback}}
#   {{path}}  ({{plugin}})
{{/each}}
{{/if}}
