---
destination: nginx.conf
---
# ─────────────────────────────────────────────────────────────────────
# nginx facade — GENERATED by mikser. DO NOT EDIT THIS FILE.
# Source of truth: runtime.routes (the route registry) + nginx.hbs.
# Edit the template (layouts/nginx.hbs) and rebuild to change it.
#
# TRUST PROXY: mikser's loopback-only enforcement (mcp / decap backend /
# loopback api endpoints) reads X-Forwarded-For, which this config sets
# on every proxied location. mikser's `trust proxy` defaults to
# 'loopback', correct when nginx runs on the SAME HOST as mikser — the
# topology assumed here. On another host/container, set
# config.server.trustProxy to that hop or those endpoints 403. Don't
# expose mikser's port directly; nginx is the only intended way in.
#
# TLS: unlike Caddy, nginx does not provision certs. Terminate TLS here
# (certbot / your own certs) and add `listen 443 ssl;` + cert paths, or
# put this behind a TLS-terminating load balancer.
# ─────────────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name {{data.host}};

    # Static output served from disk — survives a mikser restart; only
    # the dynamic routes below need mikser alive.
    root {{data.outputFolder}};

{{#each data.proxied}}
    location {{path}} {
        proxy_pass http://{{../data.upstream}};
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
{{#if streaming}}
        # {{plugin}} streams (SSE/WS) — disable buffering so frames flush
        proxy_set_header Connection        '';
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding off;
        proxy_read_timeout 24h;
{{/if}}
    }

{{/each}}
    # Files first; mikser never sees a request it doesn't need to.
    location / {
        try_files $uri $uri/index.html =404;
    }
}

{{#if data.loopback.length}}
# Not proxied — loopback-only, reachable on the mikser host only:
{{#each data.loopback}}
#   {{path}}  ({{plugin}})
{{/each}}
{{/if}}
