<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{document.meta.title}} · B#tter Truth</title>
    <link rel="stylesheet" href="/shared/styles/base.css">
    <link rel="stylesheet" href="/shared/styles/components.css">
</head>
<body>
    <div class="container">
        <nav class="byline">
            <a href="/">← Back to index</a>
        </nav>

        <article>
            <header>
                <h1>{{document.meta.title}}</h1>
                <div class="byline">
                    {{!--
                        document.meta is the projected form (projectMeta
                        in mikser-io/src/utils.js strips the `$` prefix
                        per ADR-0007), so the source's `$author` ref
                        surfaces here as `document.meta.author`. Using
                        the unprojected `document.meta.$author` would
                        render as undefined → opaque "Unknown" fallback
                        when the sidecar fails to resolve the ref.
                    --}}
                    {{#if data.author}}
                        by <a href="{{data.author.meta.href}}{{#unless data.author.meta.href}}/{{data.author.name}}{{/unless}}"><strong>{{data.author.meta.name}}</strong></a>{{#if data.author.meta.role}} · <span class="author-role">{{data.author.meta.role}}</span>{{/if}}
                    {{else if document.meta.author}}
                        by <strong><code>{{document.meta.author}}</code></strong> <small>(unresolved — author entity hasn't loaded yet; remote sources may still be polling)</small>
                    {{else}}
                        by <strong>anonymous</strong>
                    {{/if}}
                    · {{date document.meta.date 'MMMM D, YYYY'}}
                    {{#if document.meta.status}}
                        <span class="status-badge {{document.meta.status}}">{{document.meta.status}}</span>
                    {{/if}}
                </div>
            </header>

            <div class="body">
                {{{markdown document.content}}}
            </div>

            {{#if document.meta.tags}}
                <ul class="tag-list">
                    {{#each document.meta.tags}}
                        <li>{{this}}</li>
                    {{/each}}
                </ul>
            {{/if}}
        </article>
    </div>
    <script type="module" src="/live-reload.js"></script>
</body>
</html>
