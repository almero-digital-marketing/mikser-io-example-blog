# Copy this file to .env and fill in the values you want to use.
# Everything in this example works without any of these set — the only
# capabilities that degrade are vector search (no OPENAI_API_KEY),
# externally-reachable URLs (no NGROK_AUTHTOKEN), and observability
# integrations (no BETTERSTACK_*_TOKEN).

# Required for vector search (essay similarity, "find posts about X").
OPENAI_API_KEY=

# Optional: enable an ngrok tunnel to surface a public https URL.
# When set AND mikser is running with --server, the blog comes up at a
# real public URL — handy for sharing previews, testing webhook-
# capable plugins (gdrive push notifications, MCP-UI handler
# callbacks, post-email tracking links), or letting the MCP server
# accept incoming SSE from external agents. Without it, mikser runs
# on localhost only; plugins that need external reachability log a
# debug line and fall back to local behavior.
#
# Sign up at https://dashboard.ngrok.com → Get your authtoken from
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Optional: Better Stack (uptime + log management) integration.
# Each token is independent — set either, both, or neither.
#
#   BETTERSTACK_SOURCE_TOKEN     — ships every mikser log line to Better
#                                   Stack Telemetry via @logtail/pino.
#                                   Get it at: Better Stack dashboard →
#                                   Telemetry → Sources → Connect source
#                                   → Platform: JavaScript · Node.js.
#
#   BETTERSTACK_HEARTBEAT_TOKEN  — periodic ping so Better Stack Uptime
#                                   knows mikser is alive. Get it at:
#                                   Better Stack dashboard → Uptime →
#                                   Monitors → Create monitor → Type:
#                                   Heartbeat. Token is the path segment
#                                   after /api/v1/heartbeat/ in the URL.
#
# Without these set, the plugin no-ops and mikser runs normally —
# included in this example as a smoke check that the no-token case
# is harmless.
BETTERSTACK_SOURCE_TOKEN=
BETTERSTACK_HEARTBEAT_TOKEN=

# Optional: cross-source demo. When set, mikser-io-csv polls the URL
# and fans each row into an author entity at /authors/<slug>/. Posts
# reference authors via `$author: /authors/<slug>` — refs resolve to
# either the local YAML author (documents/authors/bitter-truth.yml)
# or any CSV-sourced author by id match. Both sources coexist in the
# same catalog with the same render pipeline.
#
# Easiest hosting path: Google Sheets → File → Share → Publish to web
# → Comma-separated values → copy the URL. The CSV at the repo root
# (authors.csv) is the column template — drop it into a sheet, then
# point this variable at the published URL.
#
# The URL below points at the demo sheet maintained for this example.
# Copy the spreadsheet into your own Google Drive and re-publish to
# experiment with edits without affecting the public demo.
BLOG_AUTHORS_CSV=https://docs.google.com/spreadsheets/d/e/2PACX-1vRMZbHc-vSxLwiV_muhABJ_VoQk6BUWgVeqQE3GQSfU377VFdMgIlhDhHcJaCtPpD-TJwXZ6vbP8ko8/pub?gid=0&single=true&output=csv

# Optional: override the default port (3001).
# PORT=3001
