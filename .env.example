# Copy this file to .env and fill in the values you want to use.
# Everything in this example works without any of these set — the only
# capabilities that degrade are vector search (no OPENAI_API_KEY) and
# externally-reachable URLs (no NGROK_AUTHTOKEN).

# Required for vector search (essay similarity, "find posts about X").
OPENAI_API_KEY=

# Optional: enable an ngrok tunnel to surface a public https URL.
# When set AND mikser is running with --server, the blog comes up at a
# real public URL — handy for sharing previews, testing webhook-
# capable plugins (gdrive push notifications, MCP-UI handler
# callbacks, post-email tracking links), or letting the MCP server
# accept incoming SSE from external agents. Without it, mikser runs
# on localhost only; plugins that need external reachability log a
# debug line and fall back to local behavior.
#
# Sign up at https://dashboard.ngrok.com → Get your authtoken from
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Optional: override the default port (3001).
# PORT=3001
